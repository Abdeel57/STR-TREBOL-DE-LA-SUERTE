# ================================================
# 🔐 VARIABLES DE ENTORNO - BACKEND
# ================================================
# Copia este archivo, rellena con tus valores reales
# y NUNCA lo subas a tu repositorio Git.

# --- Base de Datos PostgreSQL (Railway) ---
DATABASE_URL=postgresql://user:password@host:port/database

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Seguridad ---
# Genera un secreto largo y aleatorio, ej: openssl rand -base64 32
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_Y_LARGO

# --- CORS ---
# URLs de tu frontend separadas por comas (sin espacios)
# Ejemplo: https://micliente.netlify.app,https://www.micliente.com
CORS_ORIGINS=https://tudominio.netlify.app

# --- Cloudinary (para subida de imágenes) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- IA (verificación de comprobantes) ---
GEMINI_API_KEY=tu_gemini_api_key
